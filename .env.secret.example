# Template for AeroNet OS secrets — copy to .env.secret and fill in values
# NEVER commit the real .env.secret file

POSTGRES_PASSWORD=
SECRET_KEY=

# Juniper MIST
MIST_API_TOKEN=
MIST_SITE_ID=
MIST_POLL_INTERVAL=60
MIST_ERROR_THRESHOLD=5

# Grafana
GRAFANA_ADMIN_PASSWORD=
GRAFANA_ADMIN_USER=admin

# Internal service URLs
NOTIFIER_URL=http://notifier:8001
ENROLLER_URL=http://enroller:8002

# Enroller — Nmap scanning
SCAN_TARGETS=10.0.0.0/24,192.168.1.0/24
SCAN_INTERVAL_MINUTES=30
SCRAPLI_SSH_TIMEOUT=30
SCRAPLI_AUTH_TIMEOUT=20
CREDENTIALS_ENCRYPTION_KEY=

# Alert Contacts — Fernet key for encrypting contact PII (email, phone, chat ID)
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ALERT_CONTACTS_ENCRYPTION_KEY=

# Notifier — Telegram (primary, all severities)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Notifier — Twilio (CRITICAL + enrollment events only)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# Portal
PORTAL_PORT=8080
GRAFANA_URL=http://grafana:3000
